{
  "name": "docview-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "A framework-agnostic, universal document renderer with optional chunked loading",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
