{
  "name": "@polyrender/react",
  "version": "0.1.0",
  "description": "React components for the PolyRender universal document renderer",
  "license": "Zlib",
  "private": false,
  "type": "module",
  "homepage": "https://tangled.org/aria.pds.witchcraft.systems/polyrender/blob/main/packages/react/README.md",
  "bugs": {
    "url": "https://tangled.org/aria.pds.witchcraft.systems/polyrender/issues",
    "email": "polyrender@aria.coffee"
  },
  "author": "Aria Quinlan <hello@aria.coffee> (http://aria.coffee/)",
  "repository": {
    "type": "git",
    "url": "git+https://tangled.org/aria.pds.witchcraft.systems/polyrender",
    "directory": "packages/react"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@polyrender/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "react",
    "pdf",
    "epub",
    "docx",
    "csv",
    "odt",
    "document",
    "viewer",
    "component",
    "renderer",
    "reader",
    "chunked"
  ]
}